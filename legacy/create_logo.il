			(getEditRep) mlayer 
			(modifyCoords coords_listDMS pntr magAmount)
		    ) 
		    (dbCreatePolygon 
			(getEditRep) mlayer 
			(modifyCoords coords_listDMS1 pntr magAmount)
		    )
		) 
		("e" 
