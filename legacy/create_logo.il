procedure((leCreatePgText \@optional LPP) 
	let((cur_win rep rep_lib lname lpurp
		snapMode snapeShape text_string magAmount mtextString
		mlayer mSpaceBetween userGrid id_tech
	    ) 
	    (userGrid = ((leDisplayOptionsForm->xSnap)->value)) 
	    (libname = (dmGenOpenLibPathName)) 
	    (cln = caar(libname)) 
	    (dwindow = (geOpen ?lib cln ?cell "template"
		    ?view "layout" ?window 
		    list((5:5) 
			(250:150)
		    )
		))
	    printf("Character input is case insensitive but output will be UPPER CASE\n") 
	    printf("Any Integer May Be Used With The Following Grids: (x/y Snap)\n") 
	    printf("Multiples of 20 - Use Grid (x/y Snap of 1.0)\n") 
	    printf("Multiples of 10 - Use Grid (x/y Snap of 0.5)\n") 
	    printf("Multiples of  5 - Use Grid (x/y Snap of 0.25)\n")
	    printf("Even Multiples Other Than Above - Use a Grid (x/y Snap) of 0.1\n") 
	    printf("Odd Multiples Other Than Above - Use a Grid (x/y Snap) of 0.05\n") 
	    printf("Other Grids May Result In Line Mismatch\n") 
	    (leCreatePgTextForm) 
	    (hiZoomAbsoluteScale 
		(hiGetCurrentWindow) 0.9
	    )
	    (geSelectAllFig) 
	    (leHiMove) 
	    (geDeselectAllFig) 
	    (windowList = (hiGetWindowList)) 
	    (last = length(windowList))
	    (wid = nthelem(last windowList)) 
	    (geDiscardEdits wid) 
	    (hiCloseWindow wid)
	)
    )
procedure((leCreatePgTextForm) 
	(cur_win = (hiGetCurrentWindow)) 
	if(!cur_win then 
	    printf("A cellView must be opened to place instances in.\n") 
	    return(nil)
	) 
	(rep = (geGetWindowRep cur_win)) 
	(rep_lib = (rep~>lib))
	(id_tech = (techGetTechFile rep_lib)) 
	(lay_list = (leGetValidLayerList id_tech)) 
	(LPP = car(lay_list)) 
	(text_string = (hiCreateStringField ?name 
		'text_string ?prompt "Enter Text"
		?value "" ?defValue "" ?callback
		"" ?editable t
	    )) 
	(magAmount = (hiCreateStringField ?name 
		'magAmount ?prompt "Enter Mag"
		?value "" ?defValue "10" ?callback
		"" ?editable t
	    ))
	(layerField = (hiCreateLayerCyclicField id_tech "Layer for Polygon" "" lay_list
		LPP
	    )) 
	(layerPurpose = (hiCreateStringField ?name 
		'layerPurpose ?prompt "Purpose"
		?value "" ?defValue "drawing" ?callback
		"" ?editable t
	    )) 
	(formId = (hiCreateForm 
		'leCreatePgTextForm "GYW LOGO GENERATE" "leCreatePgTextCB()" 
		list(list(text_string 
			(0:10) 
			(260:0) 80
		    ) 
		    list(magAmount 
			(270:10) 
			(160:0) 70
		    ) 
		    list(layerField 
			(0:50) 
			(260:35) 110
		    ) 
		    list(layerPurpose 
			(270:50) 
			(160:0) 70
		    )
		)
		""
	    )) 
	(hiDisplayForm formId)
    )
procedure((leCreatePgTextCB) 
	(text_string = stringToLower(((leCreatePgTextForm->text_string)->value))) 
	(layer1 = nth(3 
		((leCreatePgTextForm->hiLayerField)->value)
	    )) 
	(mlayer = list(readstring(layer1) 
		((leCreatePgTextForm->layerPurpose)->value)
	    )) 
	printf("mlayer set to ")
	println(mlayer) 
	(magAmount = float(evalstring(((leCreatePgTextForm->magAmount)->value)))) 
	(dspace = 2) 
	(sspace = 5.0) 
	(pntr = 0)
	(mtextString = parseString(text_string "")) 
	(characterWidth = "norm") 
	foreach(character mtextString 
	    case(characterWidth 
		("norm" 
		    (pntr = (pntr + (magAmount * dspace)))
		) 
		("wide" 
		    (pntr = (pntr + (magAmount * dspace * 1.2)))
		) 
		("narrow" 
		    (pntr = (pntr + (magAmount * dspace * 0.6)))
		)
	    ) 
	    case(character 
		("m" 
		    (characterWidth = "wide")
		) 
		("w" 
		    (characterWidth = "wide")
		) 
		(("i" "'" ":" ";" "("
			")" "!" "." "[" "]"
			"1" "\""
		    ) 
		    (characterWidth = "narrow")
		) 
		(t 
		    (characterWidth = "norm")
		)
	    ) 
	    case(character 
		(" ") 
		("a" 
		    (dbCreatePolygon 
			(getEditRep) mlayer 
			(modifyCoords coords_listAMS1 pntr magAmount)
		    ) 
		    (dbCreatePolygon 
			(getEditRep) mlayer 
			(modifyCoords coords_listAMS2 pntr magAmount)
		    ) 
		    println((getEditRep))
		) 
		("b" 
		    (dbCreatePolygon 
			(getEditRep) mlayer 
			(modifyCoords coords_listBMS1 pntr magAmount)
		    ) 
		    (dbCreatePolygon 
			(getEditRep) mlayer 
			(modifyCoords coords_listBMS2 pntr magAmount)
		    )
		) 
		("c" 
